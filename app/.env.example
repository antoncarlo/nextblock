# NextBlock app environment variables
# Copy this file to `.env.local` for local development and fill values locally.
# Do not commit `.env.local` or any real secret values.

# Public browser-safe configuration.
# This value is optional in local development; use a real WalletConnect project id outside demos.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Public Supabase configuration used by browser/client-side Supabase code.
# The anon key is public by design, but keep the real project value out of this example file.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only Supabase service role key.
# Never expose this value to browser code, client bundles, logs, or public repositories.
# It must only be set in trusted server/runtime secret storage when server-side KYB routes are enabled.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: set explicitly when running local checks.
# NODE_ENV=development
