# NextBlock app environment variables
# Copy this file to `.env.local` for local development and fill values locally.
# Do not commit `.env.local` or any real secret values.

# Public browser-safe configuration.
# This value is optional in local development; use a real WalletConnect project id outside demos.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Public Supabase configuration used by browser/client-side Supabase code.
# The anon key is public by design, but keep the real project value out of this example file.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only Supabase service role key.
# Never expose this value to browser code, client bundles, logs, or public repositories.
# It must only be set in trusted server/runtime secret storage when server-side KYB routes are enabled.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional RPC override for server-side on-chain role checks (read-only),
# used by the KYB operator authorization. Defaults to the public Base Sepolia
# endpoint when unset.
BASE_SEPOLIA_RPC_URL=

# Server-only shared secret for the scheduled-job endpoints
# (notifications/audit/AI refresh, sanctions rescreen). Endpoints are
# fail-closed when unset. MUST equal the GitHub Actions secret CRON_SECRET
# that drives .github/workflows/scheduled-jobs.yml.
CRON_SECRET=

# Server-only IPFS pinning (confidential mode: only the public integrity
# manifest is pinned; documents go to the private Supabase bucket).
# /api/portfolio/pin returns 503 when PINATA_JWT is unset (fail-closed).
PINATA_JWT=
PINATA_GATEWAY=your-dedicated-gateway.mypinata.cloud

# Email channel (server-only). 'mock' (default) logs instead of sending;
# 'resend' requires RESEND_API_KEY + EMAIL_FROM (verified domain).
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM=
# Admin recipient for "new KYB application" alerts (optional).
KYB_NOTIFY_EMAIL=

# Public app URL used in emails (defaults to https://nextblock.finance).
NEXT_PUBLIC_APP_URL=

# Goldsky subgraph for redemption history (public query endpoint).
NEXT_PUBLIC_SUBGRAPH_URL=

# Live contract addresses surfaced to the client (staging generation).
NEXT_PUBLIC_REDEMPTION_QUEUE_ADDRESS=
NEXT_PUBLIC_LENDING_MARKET_ADDRESS=

# Optional email-RBAC reviewer allowlist (comma-separated addresses).
REVIEWER_ADDRESSES=

# Optional: set explicitly when running local checks.
# NODE_ENV=development
