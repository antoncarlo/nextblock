# =============================================================================
# NextBlock — Base Sepolia STAGING configuration (Phase 11)
# =============================================================================
# SECURITY:
# - TESTNET ONLY. Never put a real/production key in this file or in the repo.
# - Prefer `cast wallet` keystore or a hardware wallet over PRIVATE_KEY.
# - The deploy script hard-rejects any chain other than Base Sepolia (84532)
#   and local Anvil (31337). There is NO mainnet target in the MVP.
# =============================================================================

# --- RPC ---
# Base Sepolia RPC (e.g. https://sepolia.base.org or a provider URL)
BASE_SEPOLIA_RPC_URL=

# --- Deployer (TESTNET PLACEHOLDER KEY ONLY) ---
# Anvil default key #0 works for local runs:
# PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
PRIVATE_KEY=

# --- Explorer verification (optional) ---
# BaseScan API key for `forge script ... --verify` / `forge verify-contract`
BASESCAN_API_KEY=

# --- Settlement asset (optional) ---
# Reuse an already-deployed mock USDC; leave empty to deploy a fresh MockUSDC.
# NEVER point this at real USDC: the staging stack must not touch real funds.
USDC_ADDRESS=

# --- Canonical role addresses (optional; default = deployer for staging) ---
OWNER_ADDRESS=
CURATOR_ADDRESS=
SENTINEL_ADDRESS=
COMMITTEE_ADDRESS=
ALLOCATOR_ADDRESS=
ORACLE_ADDRESS=
CEDANT_ADDRESS=
KYC_OPERATOR_ADDRESS=

# --- Output ---
# Write deployments/<chainId>-staging.json after deploy (default: true)
WRITE_DEPLOYMENT_JSON=true
