{
  "name": "nextblock",
  "version": "0.1.0",
  "private": true,
  "author": "Anton Carlo Santoro",
  "description": "NextBlock root workspace: repo-level checks for frontend (app) and smart contracts (contracts).",
  "workspaces": [
    "app"
  ],
  "scripts": {
    "build": "npm --prefix app run build",
    "codegen:addressbook": "node scripts/generate-addressbook.mjs",
    "check:addressbook": "node scripts/check-addressbook.mjs",
    "check:natspec": "node scripts/check-natspec.mjs",
    "ci:frontend:install": "npm ci",
    "ci:frontend:lint": "npm --prefix app run lint",
    "ci:frontend:typecheck": "node node_modules/typescript/bin/tsc -p app/tsconfig.json --noEmit",
    "ci:frontend:build": "npm --prefix app run build",
    "ci:frontend": "npm run ci:frontend:install && npm run ci:frontend:lint && npm run ci:frontend:typecheck && npm run ci:frontend:build",
    "ci:contracts:fmt": "cd contracts && forge fmt --check",
    "ci:contracts:build": "cd contracts && forge build --sizes",
    "ci:contracts:test": "cd contracts && forge test -vvv",
    "audit:contracts:snapshot": "cd contracts && forge snapshot --check --tolerance 1 --no-match-test \"(testFuzz|invariant)\" --no-match-path \"test/fork/*\"",
    "audit:contracts:snapshot:update": "cd contracts && forge snapshot --no-match-test \"(testFuzz|invariant)\" --no-match-path \"test/fork/*\"",
    "audit:contracts:coverage": "cd contracts && forge coverage --report summary",
    "ci:contracts": "npm run ci:contracts:fmt && npm run ci:contracts:build && npm run ci:contracts:test",
    "ci": "npm run ci:frontend && npm run ci:contracts"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "ws": "^8.21.0"
  }
}
